# Copy this file outside the repo or into an ignored local path, then fill in
# real private values before running:
# npm run commercial:secrets -- --env-file /absolute/path/to/commercial-release.env --apply

# Tauri updater signing. TAURI_SIGNING_PRIVATE_KEY is already configured for
# this repository; set the password only when the private key is encrypted.
# TAURI_SIGNING_PRIVATE_KEY=contents-of-private-key
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Windows commercial installer signing.
WINDOWS_CODESIGN_CERTIFICATE_PATH=/absolute/path/to/windows-authenticode.pfx
WINDOWS_CODESIGN_CERTIFICATE_PASSWORD=

# Apple Developer ID signing.
APPLE_CERTIFICATE_PATH=/absolute/path/to/developer-id-application.p12
APPLE_CERTIFICATE_PASSWORD=
APPLE_SIGNING_IDENTITY=Developer ID Application: Example LLC (TEAMID1234)
KEYCHAIN_PASSWORD=

# Apple notarization. Choose either the Apple ID set or the App Store Connect
# API key set. Leave the unused set commented out.
APPLE_ID=release@example.com
APPLE_PASSWORD=app-specific-password
APPLE_TEAM_ID=TEAMID1234

# APPLE_API_ISSUER=
# APPLE_API_KEY=
# APPLE_API_PRIVATE_KEY_PATH=/absolute/path/to/AuthKey_KEYID.p8

# Optional live OpenRouter route.
# OPENROUTER_API_KEY=
